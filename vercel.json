{
  "redirects": [
    { "source": "/services",                    "destination": "/how-it-works",                 "permanent": true },
    { "source": "/services/ai-sprint",          "destination": "/engage/outcome-based-project", "permanent": true },
    { "source": "/services/ai-integration",          "destination": "/engage/managed-ai-engineer",   "permanent": true },
    { "source": "/services/maintenance",             "destination": "/engage/app-rescue",            "permanent": true },
    { "source": "/blogs",                            "destination": "/blog",                         "permanent": true },
    { "source": "/blogs/:path*",                     "destination": "/blog",                         "permanent": true },
    { "source": "/about-us-hire-developers-in-india", "destination": "/about",                        "permanent": true },
    { "source": "/about-us-hire-developers-in-india/","destination": "/about",                        "permanent": true },
    { "source": "/team",                             "destination": "/",                             "permanent": true },
    { "source": "/pricing",                          "destination": "/how-it-works",                 "permanent": true },
    { "source": "/hire",                             "destination": "/engage/managed-ai-engineer",   "permanent": true },
    { "source": "/get-started",                      "destination": "/engage/managed-ai-engineer",   "permanent": true },
    { "source": "/book",                             "destination": "/engage/managed-ai-engineer",   "permanent": true },
    { "source": "/engage/managed-ai-builder",        "destination": "/engage/managed-ai-engineer",   "permanent": true },
    { "source": "/apply-as-builder",            "destination": "/apply",                        "permanent": true },
    { "source": "/talent",                      "destination": "/apply",                        "permanent": true },
    { "source": "/careers",                     "destination": "/apply",                        "permanent": true },
    { "source": "/work",                        "destination": "/case-studies",                 "permanent": true },
    { "source": "/portfolio",                   "destination": "/case-studies",                 "permanent": true },
    { "source": "/resources",                              "destination": "/blog",          "permanent": true },
    { "source": "/how-it-works-hire-dedicated-developers", "destination": "/how-it-works",  "permanent": true },
    { "source": "/how-it-works-hire-dedicated-developers/","destination": "/how-it-works",  "permanent": true },
    { "source": "/hire-dedicated-developers",              "destination": "/engage/managed-ai-engineer", "permanent": true },
    { "source": "/hire-dedicated-developers/",             "destination": "/engage/managed-ai-engineer", "permanent": true },
    { "source": "/faq",                                    "destination": "/frequently-asked-questions", "permanent": true },
    { "source": "/faqs",                                   "destination": "/frequently-asked-questions", "permanent": true }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type",   "value": "application/xml" },
        { "key": "Cache-Control",  "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type",   "value": "text/plain" },
        { "key": "Cache-Control",  "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|gif|ico|svg|webp)$)",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:woff|woff2|ttf|otf)$)",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" }
      ]
    }
  ]
}
